# LLM 配置模板。复制为 .env 后填写;CLI 启动时自动加载(已有的环境变量不会被覆盖)。
# 三个参数都通过 LiteLLM 传给底层。也可用 --model / --api-base / --api-key 覆盖。

# 模型名(LiteLLM 约定的 provider/model 形式)
#   本地 Ollama:     ollama/qwen3:32b
#   OpenAI 兼容网关:  openai/<模型名>
LLM_MODEL=ollama/qwen3

# base_url / API 地址
#   Ollama 默认:     http://localhost:11434
#   OpenAI 兼容网关:  https://your-gateway/v1
LLM_API_BASE=http://localhost:11434

# API Key(本地 Ollama 通常留空;走网关时填)
LLM_API_KEY=

# ⚠️ 阶段裁决(逐阶段 Validator)用 LLM judge 作主裁决(2026-06-23 G1):**没有可用 LLM =
#    主裁决缺失 → 阶段整批判 FAIL**(不再 skipped 默认放过——自动化平台无人工复核环节,
#    skipped 等于被忽略=false-green 漏洞)。真实执行务必配好上面三项;单测/冒烟用 fake LLM。

# 单次 LLM 调用超时(秒)。内网大模型慢、首次冷启动久时调大,否则会被砍断 → 降级成
# 低质量朴素 Spec。要让翻译/分类正常出结果,这个值需覆盖真实响应延迟。
# LLM_TIMEOUT=300

# 底层 SDK 自动重试次数,默认 0(快速失败)。本封装已有自己的降级逻辑;慢模型下若 SDK
# 再叠加重试,单次调用要等 (1+N)×LLM_TIMEOUT,界面会长时间「卡」在某阶段。一般保持 0。
# LLM_NUM_RETRIES=0

# 绕过代理直连 LLM 主机(内网常用)。
#   现象:同一 cmd 里 curl 能连、本项目却报「代理异常/Content Filter - Access Denied」。
#   原因:Windows 下 httpx 会读取「系统/注册表代理(WinINET)」并把内网请求也发给代理,
#         而 curl 不读注册表代理 → 直连成功。两者规则不同,故同 shell 表现不一致。
#   解法:把内网 LLM 主机(LLM_API_BASE 里的主机名/IP,不带 http:// 和端口)加进 NO_PROXY,
#         httpx 即对该主机直连;公网地址仍走代理。全部走内网可直接写 NO_PROXY=*。
# NO_PROXY=localhost,127.0.0.1,your-internal-llm-host


# ───────────────────────────── 执行 / 运行时 ─────────────────────────────
# 改这些配置时,记得同步更新本文件(.env.example 是配置的唯一索引)。
#
# 【开关约定】下面所有「开关型」变量统一:  1 = 开(启用)   0 = 关(禁用)。
#   判定逻辑是「值 != "0" 即视为开」,所以填 1/true/yes 都算开,只有填 0 才算关。
#   差别只在【默认值】——下面每条都标了「默认开」还是「默认关」:
#     · 默认开 的(MCP_ISOLATED / MCP_HEADLESS / MCP_SCREENSHOT / MCP_SETTLE / HEAL_VISUAL):
#       不写就是开,要关掉才需显式写 =0。
#     · 默认关 的(JUDGE_VISUAL):不写就是关,要启用才需显式写 =1。
#   注:数值型变量(AGENT_MAX_STEPS / STEP_FAIL_BUDGET / LLM_TIMEOUT 等)不是开关,填具体数字。

# ReAct 单条用例最大步数(API 执行)。默认 40;长流程(如下单结算 11+ 业务步,叠加
# 每步多次 LLM 往返 + 自愈)会撞上限被掐断 → 用例判「执行未完成 FAIL」。结算类调到 80+。
# AGENT_MAX_STEPS=80

# 单步定位失败预算(快速失败):同一业务步累计定位失败(自愈也没救回)达此数 → 快速判
# STEP_FAILED 终止并标明卡死步(疑似前序步骤点错元素致此步找不到目标),不再磨到 max_steps。
# 默认 10(E2 3→5;2026-06-29 5→10:内网脏 live SPA 持续重渲染→nav 链接 ref 秒级失效→
# click-by-ref 5s 超时,模型靠「改用 URL 直达 / 重抓快照」恢复需要更多尝试,5/8 会在合法恢复
# 前掐断,10 才稳);干净站点几乎不触达,调小更快失败、调大更宽容。
# STEP_FAIL_BUDGET=10

# 步级卡住主动提醒预算(E2):同一业务步连续 N 轮页面指纹(URL+ref 集)未变化且未推进
# → 主动注入诊断引导(滚动/换思路/查 skill 名册),每步至多提醒一次。默认 2。
# STUCK_ROUND_BUDGET=2

# 多模态裁判通道(E6)。1=开 / 0=关,【默认关(0)】。开启后 _check_llm_judge 抓截图作第二
# 通道喂给裁判,并给裁判 prompt 拼一段「视觉证据规则」——放开**颜色/状态灯/图标/按钮配色**等
# 视觉态期望走截图判定(a11y 树丢弃样式,这类期望纯文本通道下永远拿不出逐字证据 → 被偏-FAIL
# 判 FAIL);分辨不清仍判 FAIL(偏-FAIL 不变)。需多模态模型支持;一次失败即本 run 内退回纯文本。
# 要启用才写 =1。
# JUDGE_VISUAL=1

# 驱动侧(喂模型)A11y 快照截断旋钮(Context Compact 的 L2)。近观察超过 OBS_MAX_CHARS
# (默认 4000 字符)才触发截断,截断后保留至多 SNAPSHOT_MAX_LINES 行(默认 150;企业级密集
# SPA——左侧导航+工具栏+大量 widget——40 行装不下,实测 thingsboard 首页导航链接被截掉、模型
# 找不到目标退而用 JS,故默认提到 80)。截断**优先
# 保留可交互元素行**(button/textbox/自定义组件…带 ref),即便步骤关键词没命中也留——治"步骤
# 中文、元素英文/图标 → 关键词命不中 → 目标按钮的 ref 被丢 → 模型找不到元素"。内网页面元素
# 特别多、目标仍被截掉时调大(越大每轮 token 越多)。注:与下面喂【裁判】的 JUDGE_SNAPSHOT_LIMIT
# 是两条独立路径(驱动按步骤词、裁决按期望锚点)。
# OBS_MAX_CHARS=4000
# SNAPSHOT_MAX_LINES=150
# 单条保留观察的**硬字符上限**(末位安全阀,默认 16000)。行截断后若仍超此值按字符硬切——
# 治压缩 JS/巨型 JSON 响应体整坨一行没换行(行数=1 绕过行截断,实测可达数 MB)→ 单条观察
# 撑爆 LLM 上下文窗口致整条 run 崩溃(ContextWindowExceededError)。应明显大于 OBS_MAX_CHARS。
# OBS_HARD_CHAR_CAP=12000

# 喂裁判的 A11y 快照字符上限(默认 20000)。超过则按**期望锚点**做相关度窗口截断(保留命中
# 锚点的行 + 上下文邻居),而非头部硬截断——治长页面(IoT 仪表盘等)证据(状态/数值)排在
# 头部之后被切掉、裁判"找不到证据"误判 FAIL。默认从 9000 提到 20000:企业级密集页 expected 常是
# 中文(设备/记录),但数据行是英文(Thermostat T1)→ 中文锚点只命中导航/标题、英文数据行被截
# → 误判 FAIL;调大让整页基本进视野绕开跨语言锚点失配。内网更密集页再调大,但越大裁判 token 越多。
# JUDGE_SNAPSHOT_LIMIT=20000

# 循环检测窗口:连续 N 轮完全相同的 tool_call 才判卡死终止(loop_detected)。默认 4;
# 长流程(下单结算等)偶发重复一两次快照/点击属正常,3 太敏感会误杀,可调 4~5 放宽。
# LOOP_WINDOW=4

# playwright-mcp 启动参数:无持久 profile(isolated)/ 无头(headless)。1=开 / 0=关,
# 【默认开(1)】。内网规避 Chrome「密码泄露」原生弹框(它在 a11y 快照外,自愈识别不到)。
# 要看浏览器界面(关无头)或用持久 profile,才写 =0。
# MCP_ISOLATED=1
# MCP_HEADLESS=1

# 浏览器视口尺寸「宽,高」。【默认 1920,1080】。不设视口时 playwright-mcp 用 1280×720,比常见
# 1920 屏窄,会让响应式页面把按钮收进汉堡菜单/隐藏(a11y 树里就没该元素 → agent 一直找不到),
# 且截图看着像"放大"。设 "0" 或空 = 关闭(回 playwright-mcp 默认 1280×720)。也接受 1366x768 写法。
# MCP_VIEWPORT=1920,1080

# 执行期截图捕获。1=开 / 0=关,【默认开(1)】,落 step_NNN.png 供前端抽屉预览。
# 要省磁盘/提速可关 → 写 =0。
# MCP_SCREENSHOT=0

# 导航类动作后等页面稳定(settle)。1=开 / 0=关,【默认开(1)】。关掉可能在过渡态抓快照。
# 超时/轮询间隔由下面两个数值型变量控制(单位毫秒)。
# MCP_SETTLE=0
# MCP_SETTLE_TIMEOUT_MS=8000
# MCP_SETTLE_INTERVAL_MS=400
# 阶段末尾 Validator 判前的 settle 超时(毫秒,默认 2000)。阶段末步是 mark_step_done、页面
# 多半已稳,这里只兜"点击触发的 SPA 异步内容还在渲染",短超时即可,不必沿用主 settle 的 8s
# (动态页/长轮询页会每阶段白烧满 8s)。注:显式导航 browser_navigate 已被 Playwright 自动
# 等到 'load',不再额外 settle(去冗余)。
# PHASE_SETTLE_TIMEOUT_MS=2000

# 〔2026-06-24 扫描子系统收缩〕词汇表自动扫描(主动扫描 + 执行后增量扫描 VOCAB_SCAN)
# 已整体退役——阶段化重设计后翻译不接地、裁决主走 llm_judge,自动扫描产出几乎不被消费。
# 词汇表改为纯手动维护(前端 CRUD);运行时 VocabularyResolver 仍服务断言探针/操作侧自愈。
# (原 VOCAB_SCAN / SCAN_CRAWL_DEPTH / SCAN_MAX_PAGES 已删除。)

# 「按时长等待」补齐:browser_wait_for({time:N}) 单次调用受 playwright-mcp 内部上限(~30s)
# 限制、等不满长时长 → 执行器分段累积到真实请求时长。WAIT_MAX_SECONDS 为时长上限(秒,默认
# 300=5min,防误填"等 1 小时"长期占住 worker);WAIT_CHUNK_SECONDS 为单段时长(秒,默认 20,
# 须 < playwright-mcp ~30s 内部上限,确保每段都能等满)。一般无需改。
# WAIT_MAX_SECONDS=300
# WAIT_CHUNK_SECONDS=20

# 视觉自愈截图双通道。1=开 / 0=关,【默认开(1)】,需多模态模型。**文本模型(如 DeepSeek)
# 请写 =0 关掉**:否则每次自愈会先发一条带 image_url 的请求被网关拒(BadRequest),再回退
# 纯文本(功能不受影响,只是多一次失败调用 + 日志噪声;首次失败后本 run 自动跳过图像)。
# HEAL_VISUAL=0

# ───────────────────────────── 平台 / 多租户 ─────────────────────────────
# 数据库连接串。缺省 SQLite(单机);平台部署指向 Postgres。
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/tagent

# 执行形态:embedded(默认,进程内线程,SSE 实时)/ queue(双进程,API 入队、
# scripts/worker.py 领取)。queue 模式 API 与 worker 都要设。
# RUN_MODE=queue

# 字段加密密钥(LLM api_key 等凭据落库)。不设用开发兜底密钥 + 告警,**生产必设**。
# 生成:python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# PLATFORM_SECRET_KEY=

# 鉴权:默认关 = 单机/开放模式(隐式平台管理员,全放行)。设 header 启用真实 RBAC
# (X-User 头透传用户名);M4 接 IDaaS 时换 provider 实现。
# TAGENT_AUTH=header

# HTTP 型 Custom Tool YAML(LLM 按需调用 + custom_tool 数据断言)。
# CUSTOM_TOOLS_YAML=examples/custom_tools.yaml
