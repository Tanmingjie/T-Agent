# Python
__pycache__/
*.py[cod]
.venv/
venv/
node_modules/
*.egg-info/
.pytest_cache/
.mypy_cache/

# 本地数据 / 产物
*.db
*.db-wal
*.db-shm
*.sqlite3
storage/screenshots/*
storage/generated/*
!storage/screenshots/.gitkeep
!storage/generated/.gitkeep

# Cookie / Session 缓存
.session/
*.cookies.json

# 系统
.DS_Store
.env
.env.local
frontend/.env.local

# 前端
frontend/node_modules/
frontend/dist/

# npm 本地缓存
.npm-cache/

# Midscene 本地试验目录
.midscene-poc/

# playwright-mcp 运行产物
.playwright-mcp/

# Claude Code 本地设置
.claude/settings.local.json

# Claude Code skills (通过 npx skills add 安装，各环境自行拉取)
.agents/
.claude/skills/

# brainstorming 可视化伴侣产物
.superpowers/

# UI 研究产物 (参考截图/快照)
storage/ui_research/

# 开发辅助脚本(serve.py 是文档化的官方启动器,需纳入版本控制)
scripts/*
!scripts/serve.py
!scripts/seed_demo.py
!scripts/diag_svg_snapshot.py
!scripts/midscene_runner.js

# 运行时日志(worker/queue 冒烟等),不入库
storage/*.log

# eval_fg 快照是可经 capture.py 重新抓取的 fixture 数据,不入库
eval_fg/snapshots.json

# thingsboard 用例 xlsx 含真实账号明文凭据(由 make_thingsboard_xlsx.py + TB_EMAIL/TB_PASSWORD 生成),不入库
examples/thingsboard_cases.xlsx

.idea/
